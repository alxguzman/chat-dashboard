# ── Twitch chat ────────────────────────────────────────────────
TWITCH_CHANNELS=fazebanks

# ── Twitch Helix API (for real viewer counts) ──────────────────
# Register a free app at: https://dev.twitch.tv/console
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=https://localhost:8000/auth/callback

# ── Kick chat ──────────────────────────────────────────────────
KICK_CHANNELS=ansem

# ── X Posts via Twitter API v2 ─────────────────────────────────
# Get Bearer Token at: https://developer.twitter.com → your app → Keys and Tokens
# Requires Basic plan ($100/mo) for search. Leave blank to use demo data.
X_BEARER_TOKEN=
X_SEARCH_QUERY=crypto OR bitcoin OR $BTC OR $ETH lang:en -is:retweet
